<?xml version="1.0" encoding="utf-8"?>
<layout>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/llMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/_7sdp"
        android:paddingVertical="@dimen/_5sdp"
        android:paddingLeft="@dimen/_7sdp"
        android:paddingTop="@dimen/_7sdp"
        android:paddingRight="@dimen/_7sdp"
        android:paddingBottom="@dimen/_7sdp"
        android:tag="layout/item_video_list_0">

        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/_105sdp"
            android:layout_height="@dimen/_65sdp"
            android:layout_gravity="center_vertical"
            app:cardBackgroundColor="@color/drawer"
            app:cardCornerRadius="@dimen/_5sdp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/videoArt"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <RelativeLayout
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_17sdp"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentBottom="true"
                    android:background="@drawable/duration_bg">

                    <TextView
                        android:id="@+id/txtDuration"
                        style="@style/ItemSubTitleStyle"
                        android:layout_centerInParent="true" />
                </RelativeLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp">

            <TextView
                android:id="@+id/txtVideoName"
                style="@style/ItemTitleStyle"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtVideoSize"
                    style="@style/ItemSubTitleStyle" />
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:layout_marginRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <ImageView
                android:id="@+id/imgMore"
                style="@style/MoreImageStyle"
                android:layout_gravity="center_vertical"
                android:src="@drawable/menu" />

            <ImageView
                android:id="@+id/selected"
                style="@style/MoreImageStyle"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_unchecked"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>
</layout>

