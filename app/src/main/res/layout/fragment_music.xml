<?xml version="1.0" encoding="utf-8"?>
<layout>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg"
        android:tag="layout/fragment_music_0">

        <LinearLayout
            android:id="@+id/llTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/_5sdp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/llSong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtSongs"
                        style="@style/BoldTitle"
                        android:text="@string/songs" />

                    <View
                        android:id="@+id/songsDivider"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/primarymain"
                        android:visibility="visible" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1.5"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/llFolder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/_5sdp"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtFolder"
                        style="@style/BoldTitle"
                        android:text="@string/folder" />

                    <View
                        android:id="@+id/folderDivider"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/primarymain"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1.5"
                android:background="@drawable/ripple_bg_sqaure"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/llAlbum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/_5sdp"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtAlbum"
                        style="@style/BoldTitle"
                        android:text="@string/albums" />

                    <View
                        android:id="@+id/albumDivider"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/primarymain"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/llArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtArtist"
                        style="@style/BoldTitle"
                        android:text="@string/artists" />

                    <View
                        android:id="@+id/artistDivider"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@color/primarymain"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/rlBottom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/llTop">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/songRecycle"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/folderRecycle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/albumRecycle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/artistRecycle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <RelativeLayout
                android:id="@+id/rlNoData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:visibility="visible">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgNoData"
                        android:layout_width="@dimen/_130sdp"
                        android:layout_height="@dimen/_130sdp"
                        android:src="@drawable/nodata" />

                    <TextView
                        android:id="@+id/txtNoData"
                        style="@style/BoldTitle"
                        android:layout_gravity="bottom|center_vertical|center_horizontal|center"
                        android:text="No data found" />
                </FrameLayout>
            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>

</layout>
