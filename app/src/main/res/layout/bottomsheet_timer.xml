<?xml version="1.0" encoding="utf-8"?>
<layout>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        style="@style/BottomSheetMainLL"
        android:tag="layout/bottomsheet_timer_0">

        <androidx.cardview.widget.CardView style="@style/BottomSheetMainCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp">

                <LinearLayout
                    style="@style/BottomSheetDividerLL"
                    android:layout_gravity="center_horizontal">

                    <androidx.cardview.widget.CardView style="@style/BottomSheetDividerCard" />
                </LinearLayout>

                <TextView
                    style="@style/BottomSheetText"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="@dimen/_5sdp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:layout_marginBottom="@dimen/_5sdp"
                    android:gravity="center"
                    android:text="@string/sleep_timer" />

                <LinearLayout
                    android:id="@+id/llOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        android:id="@+id/txtOff"
                        style="@style/RegularSmall"
                        android:text="Off" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll15Min"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        style="@style/RegularSmall"
                        android:text="15 Minutes" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll30Min"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        style="@style/RegularSmall"
                        android:text="30 Minutes" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll45Min"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        style="@style/RegularSmall"
                        android:text="45 Minutes" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll60Min"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        style="@style/RegularSmall"
                        android:text="60 Minutes" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/ripple_bg_sqaure">

                    <TextView
                        style="@style/RegularSmall"
                        android:text="Stop when current song ends" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="10dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</layout>

