<?xml version="1.0" encoding="utf-8"?>
<layout>

    <RelativeLayout
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/layout_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg"
        android:tag="layout/activity_audio_player_0">

        <RelativeLayout
            android:layout_above="@+id/btm1"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <include
                android:id="@+id/toolbarLayout"
                layout="@layout/toolbar_layout" />

            <TextView
                android:id="@+id/txtTitle"
                android:layout_marginRight="25dp"
                android:layout_marginLeft="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/toolbarLayout"
                android:layout_centerHorizontal="true"
                android:fontFamily="@font/bold"
                android:gravity="center"
                android:textSize="@dimen/_16sdp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/llController"
                android:layout_below="@+id/txtTitle"
                android:padding="@dimen/_40sdp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardArt"
                    android:layout_width="@dimen/_200sdp"
                    android:layout_height="@dimen/_200sdp"
                    android:layout_centerInParent="true"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/_100sdp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="@dimen/_5sdp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/_190sdp"
                        android:layout_height="@dimen/_190sdp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="@color/bg"
                        app:cardCornerRadius="@dimen/_95sdp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/imgArt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/imgPlayer"
                    android:layout_width="@dimen/_220sdp"
                    android:layout_height="@dimen/_220sdp"
                    android:layout_centerInParent="true" />

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/llController"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/llTime"
                android:layout_margin="@dimen/_10sdp">

                <ImageView
                    android:id="@+id/btnFastBackward"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/fast_backward"
                    app:tint="@color/white" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:maxHeight="@dimen/_2sdp"
                    android:progressDrawable="@drawable/progress_nightmare"
                    android:thumb="@drawable/thumb" />

                <ImageView
                    android:id="@+id/btnFastForward"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/fast_forward"
                    app:tint="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/llPlayerBtn"
                android:layout_centerHorizontal="true"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtRunningTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_18sdp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:text=" /"
                    android:textColor="@color/grey_500"
                    android:textSize="@dimen/_14sdp" />

                <TextView
                    android:id="@+id/txtTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:textColor="@color/grey_500"
                    android:textSize="@dimen/_14sdp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llPlayerBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/llBottom"
                android:layout_centerHorizontal="true"
                android:layout_marginVertical="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_marginBottom="@dimen/_20sdp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnPrevious"
                    android:layout_width="@dimen/_45sdp"
                    android:layout_height="@dimen/_45sdp"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_12sdp"
                    android:src="@drawable/backward_track" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_20sdp"
                    android:layout_marginLeft="@dimen/_20sdp"
                    android:layout_marginRight="@dimen/_20sdp">

                    <ImageView
                        android:id="@+id/playPause"
                        android:layout_width="@dimen/_45sdp"
                        android:layout_height="@dimen/_45sdp"
                        android:background="@drawable/ripple_bg"
                        android:src="@drawable/main_pause"
                        android:visibility="visible" />
                </RelativeLayout>

                <ImageView
                    android:id="@+id/btnForward"
                    android:layout_width="@dimen/_45sdp"
                    android:layout_height="@dimen/_45sdp"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_12sdp"
                    android:src="@drawable/forward_track" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBottom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_50sdp"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/llRepeating"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/repetition"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_15sdp"
                        android:src="@drawable/loop"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_15sdp"
                        android:src="@drawable/add_to_queue"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llEqualizer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_15sdp"
                        android:src="@drawable/equalizer_icon"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llSpeed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_15sdp"
                        android:src="@drawable/speed"
                        app:tint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llAddToPlaylist"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_bg_sqaure"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_15sdp"
                        android:src="@drawable/add_playlist"
                        app:tint="@color/white" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:visibility="gone" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btm1"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center"
            android:layout_alignParentBottom="true">

            <include
                android:id="@+id/reguler_banner_ad"
                layout="@layout/ads_layout_banner"
                android:visibility="visible" />

        </RelativeLayout>

    </RelativeLayout>
</layout>

