<?xml version="1.0" encoding="utf-8"?>
<layout>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/layout_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg">

        <com.demo.musicvideoplayer.utils.SaxAdvanceDrawerLayout
            android:id="@+id/drawer_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg">

            <RelativeLayout
                android:background="@color/bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <include
                    android:id="@+id/toolbarLayout"
                    layout="@layout/toolbar_layout" />

                <LinearLayout
                    android:id="@+id/llTop"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:layout_below="@+id/toolbarLayout"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:paddingLeft="@dimen/_10sdp"
                    android:paddingRight="@dimen/_10sdp">

                    <LinearLayout style="@style/TopLLStyle">

                        <androidx.cardview.widget.CardView style="@style/TopCardsStyle">

                            <LinearLayout
                                android:id="@+id/llFavourite"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/ripple_bg_sqaure"
                                android:gravity="center">

                                <LinearLayout style="@style/TopInnerLLStyle">

                                    <ImageView
                                        android:layout_width="15dp"
                                        android:layout_height="15dp"
                                        android:tint="@color/white"
                                        android:src="@drawable/iifavorite"/>

                                    <TextView
                                        android:layout_marginLeft="7dp"
                                        android:text="Favorite"
                                        android:textSize="13sp"
                                        android:fontFamily="@font/semibold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>

                                    <!--<ImageView
                                        android:layout_gravity="center"
                                        style="@style/TopImagesStyle"
                                        android:tint="@color/white"
                                        android:src="@drawable/iifavorite" />-->
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/TopLLStyle"
                        android:layout_marginLeft="@dimen/_10sdp">

                        <androidx.cardview.widget.CardView style="@style/TopCardsStyle">

                            <LinearLayout
                                android:id="@+id/llPlaylist"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/ripple_bg_sqaure"
                                android:gravity="center">

                                <LinearLayout style="@style/TopInnerLLStyle">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:tint="@color/white"
                                        android:src="@drawable/iiplaylist"/>

                                    <TextView
                                        android:layout_marginLeft="7dp"
                                        android:text="Playlist"
                                        android:textSize="13sp"
                                        android:fontFamily="@font/semibold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>

                                    <!--<ImageView
                                        style="@style/TopImagesStyle"
                                        android:tint="@color/white"
                                        android:src="@drawable/iiplaylist" />-->
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <LinearLayout
                        style="@style/TopLLStyle"
                        android:layout_marginLeft="@dimen/_10sdp"
                        android:visibility="visible">

                        <androidx.cardview.widget.CardView style="@style/TopCardsStyle">

                            <LinearLayout
                                android:id="@+id/llRecent"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/ripple_bg_sqaure"
                                android:gravity="center">

                                <LinearLayout style="@style/TopInnerLLStyle">

                                    <ImageView
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:tint="@color/white"
                                        android:src="@drawable/iihistory"/>

                                    <TextView
                                        android:layout_marginLeft="7dp"
                                        android:text="History"
                                        android:textSize="13sp"
                                        android:fontFamily="@font/semibold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>

                                    <!--<ImageView
                                        style="@style/TopImagesStyle"
                                        android:tint="@color/white"
                                        android:src="@drawable/iihistory" />-->
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_above="@+id/llBottom"
                    android:layout_below="@+id/llTop">

                    <FrameLayout
                        android:id="@+id/frame"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/llBottom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/llPlayerBottom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/dialogBg"
                        android:padding="@dimen/_8sdp"
                        android:visibility="gone">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/musicCard"
                            android:layout_width="@dimen/_45sdp"
                            android:layout_height="@dimen/_45sdp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center"
                            android:visibility="visible"
                            app:cardBackgroundColor="@color/musicIconBg"
                            app:cardCornerRadius="@dimen/_15sdp"
                            app:cardElevation="0dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="@dimen/_10sdp"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/music" />

                                <ImageView
                                    android:id="@+id/playArt"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:id="@+id/llContentPlayer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginLeft="@dimen/_10sdp"
                            android:layout_toLeftOf="@+id/llPlayer"
                            android:layout_toRightOf="@+id/musicCard"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/regular"
                                android:singleLine="true"
                                android:text="@string/add_to_favourite"
                                android:textSize="@dimen/_14sdp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtRunningTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/regular"
                                    android:text="03:30"
                                    android:textSize="@dimen/_12sdp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/regular"
                                    android:text=" / "
                                    android:textSize="@dimen/_12sdp" />

                                <TextView
                                    android:id="@+id/txtTotalTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/regular"
                                    android:text="04:30"
                                    android:textSize="@dimen/_12sdp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llPlayer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/btnPrevious"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_gravity="center_vertical"
                                android:background="@drawable/ripple_bg"
                                android:padding="@dimen/_7sdp"
                                android:src="@drawable/backward_track" />

                            <FrameLayout
                                android:id="@+id/framePlayPause"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/ripple_bg">

                                <com.google.android.material.progressindicator.CircularProgressIndicator
                                    android:id="@+id/progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:max="100"
                                    android:maxWidth="@dimen/_10sdp"
                                    android:maxHeight="@dimen/_10sdp"
                                    app:indicatorColor="@color/primarymain"
                                    app:indicatorSize="@dimen/_35sdp"
                                    app:trackColor="@color/white"
                                    app:trackThickness="@dimen/_3sdp" />

                                <ImageView
                                    android:id="@+id/playPauseImg"
                                    android:layout_width="@dimen/_30sdp"
                                    android:layout_height="@dimen/_30sdp"
                                    android:layout_gravity="center"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/main_play"
                                    android:visibility="visible" />
                            </FrameLayout>

                            <ImageView
                                android:id="@+id/btnNext"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_gravity="center_vertical"
                                android:background="@drawable/ripple_bg"
                                android:padding="@dimen/_7sdp"
                                android:src="@drawable/forward_track" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/llNavMenu"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_55sdp"
                        android:layout_alignParentBottom="true"
                        android:background="@color/bottomBg"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/llVideo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/ripple_bg_sqaure"
                            android:gravity="center"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/imgVideo"
                                    android:layout_width="@dimen/_25sdp"
                                    android:layout_height="@dimen/_25sdp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/_2sdp"
                                    android:src="@drawable/iivideoplayer" />

                                <TextView
                                    android:id="@+id/txtVideo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/semibold"
                                    android:includeFontPadding="false"
                                    android:text="@string/video"
                                    android:textSize="@dimen/_12sdp"
                                    android:visibility="visible" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llMusic"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/ripple_bg_sqaure"
                            android:gravity="center"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/imgMusic"
                                    android:layout_width="@dimen/_25sdp"
                                    android:layout_height="@dimen/_25sdp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/_3sdp"
                                    android:src="@drawable/iimusicplayer" />

                                <TextView
                                    android:id="@+id/txtMusic"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/semibold"
                                    android:includeFontPadding="false"
                                    android:text="@string/music"
                                    android:textSize="@dimen/_12sdp"
                                    android:visibility="visible" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llSetting"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/ripple_bg_sqaure"
                            android:gravity="center"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/imgSetting"
                                    android:layout_width="@dimen/_25sdp"
                                    android:layout_height="@dimen/_25sdp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/_3sdp"
                                    android:src="@drawable/iisetting" />

                                <TextView
                                    android:id="@+id/txtSetting"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/semibold"
                                    android:includeFontPadding="false"
                                    android:text="@string/setting"
                                    android:textSize="@dimen/_12sdp"
                                    android:visibility="visible" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:visibility="gone" />

            </RelativeLayout>

            <com.google.android.material.navigation.NavigationView
                android:id="@+id/nav_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:fitsSystemWindows="true"
                app:menu="@menu/activity_main_drawerhdvideo" />

        </com.demo.musicvideoplayer.utils.SaxAdvanceDrawerLayout>

    </RelativeLayout>

</layout>

