<?xml version="1.0" encoding="utf-8"?>
<layout>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/rl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:tag="layout/activity_video_player_0">

        <RelativeLayout
            android:id="@+id/rlZoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">

            <FrameLayout
                android:id="@+id/frameTemp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true">

                <TextureView
                    android:id="@+id/surface_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>
        </RelativeLayout>

        <View
            android:id="@+id/nightView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@color/popup_layer"
            android:visibility="gone" />

        <RelativeLayout
            android:id="@+id/rlMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_110sdp"
                android:layout_alignParentTop="true"
                android:visibility="gone"
                android:background="@drawable/player_divider_top" />

            <RelativeLayout
                android:id="@+id/rlTop"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_alignParentTop="true"
                android:padding="@dimen/_10sdp">

                <ImageView
                    android:id="@+id/back"
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_3sdp"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:layout_toRightOf="@+id/back"
                    android:fontFamily="@font/semibold"
                    android:singleLine="true"
                    android:textSize="@dimen/_13sdp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/iconRecycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rlTop" />

            <RelativeLayout
                android:id="@+id/rlCenter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true">

                <RelativeLayout
                    android:layout_width="@dimen/_280sdp"
                    android:layout_height="@dimen/_100sdp"
                    android:layout_centerInParent="true">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/backward"
                        android:layout_width="@dimen/_100sdp"
                        android:layout_height="@dimen/_80sdp"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        app:lottie_autoPlay="true"
                        app:lottie_fileName="new_backwards.json"
                        app:lottie_loop="true"
                        app:lottie_speed="1" />

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/forward"
                        android:layout_width="@dimen/_100sdp"
                        android:layout_height="@dimen/_80sdp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        app:lottie_autoPlay="true"
                        app:lottie_fileName="new_forwards.json"
                        app:lottie_loop="true"
                        app:lottie_speed="1" />
                </RelativeLayout>

                <ImageView
                    android:id="@+id/screenshot"
                    android:layout_marginRight="10dp"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/screenshot" />
            </RelativeLayout>

            <FrameLayout
                android:id="@+id/frame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true">

                <ImageView
                    android:id="@+id/imgSS"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.5" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_100sdp"
                android:layout_alignParentBottom="true"
                android:visibility="gone"
                android:background="@drawable/player_divider_bottom" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/rlBottom"
                android:padding="@dimen/_10sdp">

                <TextView
                    android:id="@+id/txtRunningTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/regular"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_12sdp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toLeftOf="@+id/txtTotalTime"
                    android:layout_toRightOf="@+id/txtRunningTime"
                    android:maxHeight="@dimen/_3sdp"
                    android:paddingVertical="@dimen/_5sdp"
                    android:paddingTop="@dimen/_5sdp"
                    android:paddingBottom="@dimen/_5sdp"
                    android:progressDrawable="@drawable/progress_nightmare"
                    android:thumb="@drawable/thumb" />

                <TextView
                    android:id="@+id/txtTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/regular"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_12sdp" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rlBottom"
                android:layout_marginRight="15dp"
                android:layout_marginLeft="15dp"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:padding="@dimen/_10sdp">

                <ImageView
                    android:id="@+id/unlock"
                    android:layout_width="@dimen/_23sdp"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_3sdp"
                    android:src="@drawable/unlock" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btnBackward"
                        android:layout_width="@dimen/_23sdp"
                        android:layout_height="@dimen/_23sdp"
                        android:background="@drawable/ripple_bg"
                        android:padding="@dimen/_5sdp"
                        android:src="@drawable/backward_track"
                        app:tint="@color/white" />

                    <RelativeLayout
                        android:id="@+id/rlPlayPause"
                        android:layout_width="@dimen/_25sdp"
                        android:layout_height="@dimen/_25sdp"
                        android:layout_marginHorizontal="@dimen/_20sdp"
                        android:layout_marginLeft="@dimen/_20sdp"
                        android:layout_marginRight="@dimen/_20sdp"
                        android:background="@drawable/ripple_bg"
                        android:padding="@dimen/_3sdp">

                        <ImageView
                            android:id="@+id/imgPlayPause"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/pause"
                            app:tint="@color/white" />
                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/btnForward"
                        android:layout_width="@dimen/_23sdp"
                        android:layout_height="@dimen/_23sdp"
                        android:background="@drawable/ripple_bg"
                        android:padding="@dimen/_5sdp"
                        android:src="@drawable/forward_track"
                        app:tint="@color/white" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/scale"
                    android:layout_width="@dimen/_23sdp"
                    android:layout_height="@dimen/_23sdp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/ripple_bg"
                    android:padding="@dimen/_3sdp"
                    android:src="@drawable/full" />
            </RelativeLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/llForwarding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_center_window"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgForwarding"
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/forward_forwarding" />

            <TextView
                android:id="@+id/txtForwardingTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/semibold"
                android:gravity="center_horizontal"
                android:textColor="@color/white"
                android:textSize="@dimen/_16sdp" />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/rlProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:padding="@dimen/_10sdp">

            <com.kannada.musicplayer.utils.LightProgressView
                android:id="@+id/mLightPeogressView"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bg_center_window"
                android:padding="10dp"
                android:visibility="gone"
                app:lpv_halo_color="@android:color/white"
                app:lpv_halo_height="7dp"
                app:lpv_halo_width="2dp"
                app:lpv_moon_color="@android:color/white" />

            <com.kannada.musicplayer.utils.VolumeProgressView
                android:id="@+id/mVolumeProgressView"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bg_center_window"
                android:padding="@dimen/_10sdp"
                android:visibility="gone"
                app:vpv_halo_color="@android:color/white"
                app:vpv_halo_height="7dp"
                app:vpv_halo_width="2dp" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/lock"
            android:layout_marginLeft="10dp"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_centerVertical="true"
            android:background="@drawable/ripple_bg"
            android:padding="@dimen/_5sdp"
            android:src="@drawable/lock"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone" />
    </RelativeLayout>
</layout>

