<resources>
  <declare-styleable name="TemplateView">
    <attr name="gnt_template_type" format="reference"/>
  </declare-styleable>
    <declare-styleable name="LightProgressView">
      <attr name="lpv_halo_color" format="color">
      </attr>
      <attr name="lpv_halo_height" format="dimension">
      </attr>
      <attr name="lpv_halo_width" format="dimension">
      </attr>
      <attr name="lpv_magicnum" format="float">
      </attr>
      <attr name="lpv_moon_color" format="color">
      </attr>
      <attr name="lpv_num_of_halo" format="integer">
      </attr>
    </declare-styleable>
  <declare-styleable name="VolumeProgressView">
    <attr name="vpv_halo_color" format="color">
    </attr>
    <attr name="vpv_halo_height" format="dimension">
    </attr>
    <attr name="vpv_halo_width" format="dimension">
    </attr>
    <attr name="vpv_num_of_halo" format="integer">
    </attr>
    <attr name="vpv_volume_high" format="integer">
    </attr>
    <attr name="vpv_volume_low" format="integer">
    </attr>
    <attr name="vpv_volume_medium" format="integer">
    </attr>
  </declare-styleable>

  <attr name="defaultFooterColor" format="color"></attr>
  <attr name="iconColor" format="color"></attr>

  <declare-styleable name="VerticalSeekBar">
    <attr name="seekBarRotation">
      <!-- Clock wise - 90 deg; top = min, bottom = max -->
      <enum name="CW90" value="90" />
      <!-- Clock wise - 270 deg; bottom = min, top = max -->
      <enum name="CW270" value="270" />
    </attr>
  </declare-styleable>

</resources>
